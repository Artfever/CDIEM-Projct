<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/17.0.6"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.project.controller.ManageCaseClosureController"
           styleClass="closure-root">
    <children>
        <BorderPane maxWidth="1220.0" prefWidth="1160.0" styleClass="closure-shell">
            <top>
                <HBox alignment="CENTER_LEFT" spacing="18.0" styleClass="closure-header">
                    <children>
                        <VBox spacing="4.0">
                            <children>
                                <Label text="CDIEM" styleClass="app-tag" />
                                <Label text="Manage Case Closure" styleClass="view-title" />
                                <Label fx:id="subtitleLabel"
                                       text="Approve eligible supervisor-review cases for closure or send them back for further investigation."
                                       styleClass="view-subtitle"
                                       wrapText="true" />
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <VBox alignment="CENTER_RIGHT" spacing="5.0">
                            <children>
                                <Label fx:id="roleLabel" text="Role" styleClass="header-chip" />
                                <Label fx:id="identityLabel" text="Identity" styleClass="identity-label" />
                            </children>
                        </VBox>
                        <Button mnemonicParsing="false"
                                onAction="#goBackToDashboard"
                                text="Dashboard"
                                styleClass="action-button secondary-action" />
                    </children>
                    <padding>
                        <Insets bottom="28.0" left="28.0" right="28.0" top="28.0" />
                    </padding>
                </HBox>
            </top>
            <center>
                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="closure-scroll">
                    <content>
                        <VBox spacing="18.0" styleClass="content-pane">
                            <padding>
                                <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
                            </padding>
                            <children>
                                <HBox alignment="TOP_LEFT" spacing="18.0">
                                    <children>
                                        <VBox HBox.hgrow="ALWAYS" spacing="18.0">
                                            <VBox spacing="16.0" styleClass="panel panel-main">
                                                <children>
                                                    <VBox spacing="4.0">
                                                        <children>
                                                            <Label text="Action Context" styleClass="panel-title" />
                                                            <Label text="Load the latest supervisor-review case snapshot before approving closure or returning the case to forensic review."
                                                                   styleClass="panel-subtitle"
                                                                   wrapText="true" />
                                                        </children>
                                                    </VBox>
                                                    <GridPane hgap="14.0" vgap="14.0">
                                                        <columnConstraints>
                                                            <ColumnConstraints halignment="LEFT" minWidth="140.0" />
                                                            <ColumnConstraints hgrow="ALWAYS" minWidth="260.0" />
                                                            <ColumnConstraints minWidth="150.0" />
                                                        </columnConstraints>
                                                        <children>
                                                            <Label text="Case ID" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                                            <TextField fx:id="caseIdField"
                                                                       promptText="Enter case ID"
                                                                       styleClass="field-input"
                                                                       GridPane.columnIndex="1"
                                                                       GridPane.rowIndex="0" />
                                                            <Button fx:id="loadSnapshotButton"
                                                                    mnemonicParsing="false"
                                                                    onAction="#loadCaseSnapshot"
                                                                    text="Load Snapshot"
                                                                    styleClass="action-button secondary-action"
                                                                    GridPane.columnIndex="2"
                                                                    GridPane.rowIndex="0" />
                                                        </children>
                                                    </GridPane>
                                                </children>
                                                <padding>
                                                    <Insets bottom="22.0" left="24.0" right="24.0" top="22.0" />
                                                </padding>
                                            </VBox>

                                            <VBox fx:id="approvalPanel" spacing="16.0" styleClass="panel panel-main">
                                                <children>
                                                    <VBox spacing="4.0">
                                                        <children>
                                                            <Label text="Approve Closure" styleClass="panel-title" />
                                                            <Label text="Close the case only when it remains in SUPERVISOR_REVIEW and the latest evidence is VERIFIED."
                                                                   styleClass="panel-subtitle"
                                                                   wrapText="true" />
                                                        </children>
                                                    </VBox>
                                                    <Button fx:id="approveClosureButton"
                                                            mnemonicParsing="false"
                                                            onAction="#approveClosure"
                                                            text="Approve and Close Case"
                                                            styleClass="action-button success-action" />
                                                </children>
                                                <padding>
                                                    <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
                                                </padding>
                                            </VBox>

                                            <VBox fx:id="rejectionPanel" spacing="16.0" styleClass="panel panel-main">
                                                <children>
                                                    <VBox spacing="4.0">
                                                        <children>
                                                            <Label text="Reject Closure" styleClass="panel-title" />
                                                            <Label text="Record the supervisory reason and move the case back to FORENSIC_REVIEW for further investigation."
                                                                   styleClass="panel-subtitle"
                                                                   wrapText="true" />
                                                        </children>
                                                    </VBox>
                                                    <Label text="Rejection Reason" styleClass="field-label" />
                                                    <TextArea fx:id="rejectionReasonArea"
                                                              promptText="Enter the reason for rejecting case closure"
                                                              prefRowCount="4"
                                                              wrapText="true"
                                                              styleClass="field-input text-block" />
                                                    <Button fx:id="rejectClosureButton"
                                                            mnemonicParsing="false"
                                                            onAction="#rejectClosure"
                                                            text="Reject and Return to Forensic Review"
                                                            styleClass="action-button danger-action" />
                                                </children>
                                                <padding>
                                                    <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
                                                </padding>
                                            </VBox>
                                        </VBox>

                                        <VBox prefWidth="360.0" spacing="18.0">
                                            <VBox spacing="16.0" styleClass="panel panel-side">
                                                <children>
                                                    <VBox spacing="4.0">
                                                        <children>
                                                            <Label text="Current Case Snapshot" styleClass="panel-title" />
                                                            <Label text="Case, evidence, and latest closure decision context for the selected case ID."
                                                                   styleClass="panel-subtitle"
                                                                   wrapText="true" />
                                                        </children>
                                                    </VBox>
                                                    <GridPane hgap="12.0" vgap="12.0">
                                                        <columnConstraints>
                                                            <ColumnConstraints halignment="LEFT" minWidth="130.0" />
                                                            <ColumnConstraints hgrow="ALWAYS" minWidth="180.0" />
                                                        </columnConstraints>
                                                        <children>
                                                            <Label text="Case State" styleClass="snapshot-key" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                                            <Label fx:id="caseStatusValueLabel" text="No case loaded" wrapText="true" styleClass="snapshot-value" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                                            <Label text="Assigned Officer" styleClass="snapshot-key" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                                            <Label fx:id="assignedOfficerValueLabel" text="Unavailable" wrapText="true" styleClass="snapshot-value" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                                            <Label text="Severity" styleClass="snapshot-key" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                                            <Label fx:id="severityValueLabel" text="Unavailable" wrapText="true" styleClass="snapshot-value" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                                                            <Label text="Priority" styleClass="snapshot-key" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                                                            <Label fx:id="priorityValueLabel" text="Unavailable" wrapText="true" styleClass="snapshot-value" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                                                            <Label text="Created At" styleClass="snapshot-key" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                                                            <Label fx:id="createdAtValueLabel" text="Unavailable" wrapText="true" styleClass="snapshot-value" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                                                            <Label text="Evidence Status" styleClass="snapshot-key" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                                                            <Label fx:id="evidenceStatusValueLabel" text="No evidence loaded" wrapText="true" styleClass="snapshot-value" GridPane.columnIndex="1" GridPane.rowIndex="5" />

                                                            <Label text="Evidence File" styleClass="snapshot-key" GridPane.columnIndex="0" GridPane.rowIndex="6" />
                                                            <Label fx:id="fileNameValueLabel" text="No evidence file recorded" wrapText="true" styleClass="snapshot-value" GridPane.columnIndex="1" GridPane.rowIndex="6" />

                                                            <Label text="Integrity" styleClass="snapshot-key" GridPane.columnIndex="0" GridPane.rowIndex="7" />
                                                            <Label fx:id="integritySummaryValueLabel" text="Closure approval is blocked until verified evidence exists." wrapText="true" styleClass="snapshot-value" GridPane.columnIndex="1" GridPane.rowIndex="7" />

                                                            <Label text="Latest Decision" styleClass="snapshot-key" GridPane.columnIndex="0" GridPane.rowIndex="8" />
                                                            <Label fx:id="latestDecisionValueLabel" text="No closure decision recorded" wrapText="true" styleClass="snapshot-value" GridPane.columnIndex="1" GridPane.rowIndex="8" />

                                                            <Label text="Decision By" styleClass="snapshot-key" GridPane.columnIndex="0" GridPane.rowIndex="9" />
                                                            <Label fx:id="decisionByValueLabel" text="Unavailable" wrapText="true" styleClass="snapshot-value" GridPane.columnIndex="1" GridPane.rowIndex="9" />

                                                            <Label text="Decision Time" styleClass="snapshot-key" GridPane.columnIndex="0" GridPane.rowIndex="10" />
                                                            <Label fx:id="decisionTimeValueLabel" text="Unavailable" wrapText="true" styleClass="snapshot-value" GridPane.columnIndex="1" GridPane.rowIndex="10" />

                                                            <Label text="Decision Note" styleClass="snapshot-key" GridPane.columnIndex="0" GridPane.rowIndex="11" />
                                                            <Label fx:id="decisionReasonValueLabel" text="No approval or rejection has been recorded for this case yet." wrapText="true" styleClass="snapshot-value" GridPane.columnIndex="1" GridPane.rowIndex="11" />
                                                        </children>
                                                    </GridPane>
                                                </children>
                                                <padding>
                                                    <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
                                                </padding>
                                            </VBox>

                                            <VBox spacing="8.0" styleClass="context-card">
                                                <children>
                                                    <Label text="Workflow Access" styleClass="context-title" />
                                                    <Label fx:id="accessSummaryLabel"
                                                           text="Role-aware workflow summary appears here."
                                                           styleClass="context-text"
                                                           wrapText="true" />
                                                </children>
                                                <padding>
                                                    <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                                                </padding>
                                            </VBox>
                                        </VBox>
                                    </children>
                                </HBox>

                                <Label fx:id="statusLabel" text="Ready." wrapText="true" styleClass="status-banner status-neutral" />
                            </children>
                        </VBox>
                    </content>
                </ScrollPane>
            </center>
        </BorderPane>
    </children>
</StackPane>
