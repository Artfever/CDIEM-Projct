<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/17.0.6"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.project.controller.CaseController"
           styleClass="app-root">
    <children>
        <BorderPane maxWidth="1180.0" prefWidth="1120.0" styleClass="shell">
            <top>
                <HBox alignment="CENTER_LEFT" spacing="18.0" styleClass="header-bar">
                    <children>
                        <VBox spacing="4.0">
                            <children>
                                <Label text="CDIEM" styleClass="app-tag" />
                                <Label text="Manage Case" styleClass="view-title" />
                                <Label text="Register new cases, adjust severity, reassign investigating ownership, and delete cases." styleClass="view-subtitle" wrapText="true" />
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" onAction="#goBackToDashboard" text="Dashboard" styleClass="action-button secondary-action header-action-button" />
                        <Label text="Module 01" styleClass="header-chip" />
                    </children>
                    <padding>
                        <Insets bottom="28.0" left="28.0" right="28.0" top="28.0" />
                    </padding>
                </HBox>
            </top>
            <center>
                <VBox spacing="18.0" styleClass="content-pane">
                    <padding>
                        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
                    </padding>
                    <children>
                        <HBox alignment="TOP_LEFT" spacing="18.0">
                            <children>
                                <VBox HBox.hgrow="ALWAYS" spacing="18.0" styleClass="panel panel-main">
                                    <children>
                                        <VBox spacing="4.0">
                                            <children>
                                                <Label text="Case Registration" styleClass="panel-title" />
                                                <Label text="Capture the required information for a new cybercrime case record." styleClass="panel-subtitle" wrapText="true" />
                                            </children>
                                        </VBox>
                                        <GridPane hgap="16.0" vgap="16.0">
                                            <columnConstraints>
                                                <ColumnConstraints halignment="RIGHT" minWidth="150.0" prefWidth="180.0" />
                                                <ColumnConstraints hgrow="ALWAYS" minWidth="260.0" />
                                            </columnConstraints>
                                            <children>
                                                <Label text="Title" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                                <TextField fx:id="titleField" promptText="Enter case title" styleClass="field-input" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                                <Label text="Severity" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                                <ComboBox fx:id="severityBox" promptText="Select severity" prefWidth="280.0" styleClass="field-input combo-input" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                                <Label fx:id="descriptionLabel" text="Description" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                                <TextArea fx:id="descriptionArea" promptText="Enter case description" prefRowCount="4" wrapText="true" styleClass="field-input text-block" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                                                <Label fx:id="relatedInfoLabel" text="Related Information" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                                                <TextArea fx:id="relatedInfoArea" promptText="Optional contextual information" prefRowCount="3" wrapText="true" styleClass="field-input text-block" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                                            </children>
                                        </GridPane>
                                    </children>
                                    <padding>
                                        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
                                    </padding>
                                </VBox>
                                <VBox prefWidth="320.0" spacing="18.0" styleClass="panel panel-side">
                                    <children>
                                        <VBox spacing="4.0">
                                            <children>
                                                <Label text="Action Context" styleClass="panel-title" />
                                                <Label text="Select the acting user and provide the target case reference for supervisor actions, including deletion." styleClass="panel-subtitle" wrapText="true" />
                                            </children>
                                        </VBox>
                                        <GridPane hgap="12.0" vgap="16.0">
                                            <columnConstraints>
                                                <ColumnConstraints halignment="LEFT" minWidth="120.0" />
                                                <ColumnConstraints hgrow="ALWAYS" minWidth="140.0" />
                                            </columnConstraints>
                                            <children>
                                                <Label text="Acting User" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                                <ComboBox fx:id="currentUserBox" promptText="Select acting user" styleClass="field-input combo-input user-picker" GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.columnSpan="2" />

                                                <Label text="Case ID" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                                <TextField fx:id="caseIdField" promptText="Required for update actions" styleClass="field-input" GridPane.columnIndex="0" GridPane.rowIndex="3" GridPane.columnSpan="2" />

                                                <Label fx:id="assignedOfficerLabel" text="Investigating Officer" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                                                <ComboBox fx:id="assignedOfficerBox" promptText="Select new investigating officer" styleClass="field-input combo-input user-picker" GridPane.columnIndex="0" GridPane.rowIndex="5" GridPane.columnSpan="2" />
                                            </children>
                                        </GridPane>
                                        <VBox spacing="8.0" styleClass="context-card">
                                            <children>
                                                <Label text="Permissions" styleClass="context-title" />
                                                <Label text="Investigating Officers register new cases. Supervisory Authority users control severity updates, reassignment, and deletion at any case state. Severity changes recalculate SLA and priority, reassignment notifies officers, and deleting a case removes its database record while notifying the assigned investigating officer." styleClass="context-text" wrapText="true" />
                                            </children>
                                            <padding>
                                                <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                                            </padding>
                                        </VBox>
                                    </children>
                                    <padding>
                                        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
                                    </padding>
                                </VBox>
                            </children>
                        </HBox>
                        <VBox spacing="14.0" styleClass="panel action-panel">
                            <children>
                                <Label text="Manage Case Actions" styleClass="panel-title" />
                                <FlowPane hgap="10.0" vgap="10.0" prefWrapLength="900.0">
                                    <children>
                                        <Button fx:id="registerCaseButton" mnemonicParsing="false" onAction="#registerCase" text="Register Case" styleClass="action-button primary-action" />
                                        <Button fx:id="updateSeverityButton" mnemonicParsing="false" onAction="#updateSeverity" text="Update Severity" styleClass="action-button secondary-action" />
                                        <Button fx:id="reassignOfficerButton" mnemonicParsing="false" onAction="#reassignOfficer" text="Reassign Investigating Officer" styleClass="action-button secondary-action" />
                                        <Button fx:id="deleteCaseButton" mnemonicParsing="false" onAction="#deleteCase" text="Delete Case" styleClass="action-button danger-action" />
                                    </children>
                                </FlowPane>
                                <Label fx:id="statusLabel" text="Ready." wrapText="true" styleClass="status-banner status-neutral" />
                            </children>
                            <padding>
                                <Insets bottom="22.0" left="24.0" right="24.0" top="22.0" />
                            </padding>
                        </VBox>
                    </children>
                </VBox>
            </center>
        </BorderPane>
    </children>
</StackPane>
