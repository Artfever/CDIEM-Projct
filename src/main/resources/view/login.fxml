<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/17.0.6"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.project.controller.LoginController"
           styleClass="login-root">
    <children>
        <VBox alignment="CENTER_LEFT" maxWidth="440.0" prefWidth="440.0" spacing="22.0" styleClass="login-shell">
            <children>
                <VBox spacing="6.0">
                    <children>
                        <Label text="CDIEM" styleClass="login-tag" />
                        <Label text="Access Portal" styleClass="login-title" />
                        <Label text="Sign in to continue to your role-based case, evidence, and reporting workspace." styleClass="login-subtitle" wrapText="true" />
                    </children>
                </VBox>

                <VBox spacing="12.0">
                    <children>
                        <Label text="Username / Email" styleClass="input-label" />
                        <TextField fx:id="identifierField" promptText="Enter username or email" styleClass="input-field" />

                        <Label text="Password" styleClass="input-label" />
                        <PasswordField fx:id="passwordField" onAction="#login" promptText="Enter password" styleClass="input-field" />
                    </children>
                </VBox>

                <Button mnemonicParsing="false" onAction="#login" text="Login" styleClass="login-button" />

                <HBox alignment="CENTER_LEFT" spacing="6.0">
                    <children>
                        <Label text="Need an account?" styleClass="nav-text" />
                        <Hyperlink mnemonicParsing="false" onAction="#showSignUp" text="Sign Up" styleClass="nav-link" />
                    </children>
                </HBox>

                <VBox spacing="5.0" styleClass="credential-card">
                    <children>
                        <Label text="Seeded access" styleClass="credential-title" />
                        <Label text="Use any seeded username or email with password `CDIEM@123` after applying the new migration." styleClass="credential-text" wrapText="true" />
                    </children>
                    <padding>
                        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                    </padding>
                </VBox>

                <Label fx:id="statusLabel" text="Ready." wrapText="true" styleClass="status-banner status-neutral" />
            </children>
            <padding>
                <Insets bottom="32.0" left="32.0" right="32.0" top="32.0" />
            </padding>
        </VBox>
    </children>
</StackPane>
